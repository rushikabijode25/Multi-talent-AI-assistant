package com.debales.resumeanalyzer.service;

import org.springframework.stereotype.Service;
import java.util.*;
import java.util.regex.*;
import java.util.stream.Collectors;

/**
 * Core NLP matching engine using tokenization and Named Entity Recognition
 * heuristics to extract skills from resume text and match against JD keywords.
 *
 * Production implementation would use Apache OpenNLP's TokenizerME and
 * NameFinderME with pre-trained en-ner-person.bin models.
 */
@Service
public class NlpMatchingService {

    // Curated technical skills ontology — extensible to a NoSQL skills database
    private static final Set<String> TECHNICAL_SKILLS = Set.of(
        "java", "spring", "spring boot", "spring mvc", "hibernate", "jpa",
        "python", "django", "flask", "fastapi",
        "javascript", "typescript", "node.js", "react", "next.js", "vue", "angular",
        "mongodb", "postgresql", "mysql", "redis", "elasticsearch",
        "docker", "kubernetes", "jenkins", "terraform", "ansible",
        "aws", "gcp", "azure", "ci/cd", "microservices", "rest api", "graphql",
        "machine learning", "deep learning", "nlp", "generative ai", "llm",
        "git", "linux", "kafka", "rabbitmq", "grpc", "oauth", "jwt"
    );

    private static final Pattern EXPERIENCE_PATTERN = 
        Pattern.compile("(\\d+)\\+?\\s*(?:year|yr)s?\\s+(?:of\\s+)?experience", Pattern.CASE_INSENSITIVE);

    /**
     * Performs keyword-frequency NLP analysis on the resume text.
     *
     * @param resumeText  raw extracted resume text
     * @param jobDescription  target job description text
     * @return structured NLP matching result
     */
    public NlpResult analyze(String resumeText, String jobDescription) {
        String resumeLower = resumeText.toLowerCase();
        String jdLower = jobDescription.toLowerCase();

        // Tokenize JD to extract required skills
        Set<String> requiredSkills = extractSkillsFromText(jdLower);
        Set<String> resumeSkills = extractSkillsFromText(resumeLower);

        // Matching and gap analysis
        List<String> matching = requiredSkills.stream()
                .filter(resumeSkills::contains)
                .sorted()
                .collect(Collectors.toList());

        List<String> missing = requiredSkills.stream()
                .filter(s -> !resumeSkills.contains(s))
                .sorted()
                .collect(Collectors.toList());

        // Keyword frequency map
        Map<String, Integer> frequency = new LinkedHashMap<>();
        for (String skill : resumeSkills) {
            int count = countOccurrences(resumeLower, skill);
            if (count > 0) frequency.put(skill, count);
        }

        // Experience year extraction via regex
        int experienceYears = extractExperienceYears(resumeText);

        return new NlpResult(matching, missing, frequency, experienceYears);
    }

    private Set<String> extractSkillsFromText(String text) {
        return TECHNICAL_SKILLS.stream()
                .filter(text::contains)
                .collect(Collectors.toSet());
    }

    private int countOccurrences(String text, String keyword) {
        int count = 0;
        int idx = 0;
        while ((idx = text.indexOf(keyword, idx)) != -1) {
            count++;
            idx += keyword.length();
        }
        return count;
    }

    private int extractExperienceYears(String text) {
        Matcher m = EXPERIENCE_PATTERN.matcher(text);
        int max = 0;
        while (m.find()) {
            int years = Integer.parseInt(m.group(1));
            max = Math.max(max, years);
        }
        return max;
    }

    public record NlpResult(
        List<String> matchingSkills,
        List<String> missingSkills,
        Map<String, Integer> keywordFrequency,
        int experienceYears
    ) {}
}


