package com.debales.resumeanalyzer.controller;

import com.debales.resumeanalyzer.model.AnalysisResult;
import com.debales.resumeanalyzer.service.*;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

/**
 * REST Controller exposing the resume analysis endpoint.
 * 
 * POST /api/v1/analyze
 *   @param file            — PDF resume (multipart)
 *   @param jobDescription  — Target JD text
 * 
 * Returns AnalysisResult JSON with ATS score, NLP skills, AI feedback.
 */
@Slf4j
@RestController
@RequestMapping("/api/v1")
@RequiredArgsConstructor
@CrossOrigin(origins = "${cors.allowed-origins}")
public class ResumeController {

    private final ResumeParserService parserService;
    private final NlpMatchingService nlpService;
    private final GeminiScoringService geminiService;

    @PostMapping("/analyze")
    public ResponseEntity<AnalysisResult> analyze(
            @RequestParam("file") MultipartFile file,
            @RequestParam("jobDescription") String jobDescription) {

        if (file.isEmpty()) {
            return ResponseEntity.badRequest().build();
        }

        try {
            log.info("Analyzing resume: {} ({} bytes)", file.getOriginalFilename(), file.getSize());

            // Step 1 — Extract raw text from PDF
            String resumeText = parserService.extractText(file);
            log.info("Extracted {} characters from resume", resumeText.length());

            // Step 2 — NLP Keyword Matching
            NlpMatchingService.NlpResult nlpResult = nlpService.analyze(resumeText, jobDescription);
            log.info("NLP matched {} / {} required skills",
                    nlpResult.matchingSkills().size(),
                    nlpResult.matchingSkills().size() + nlpResult.missingSkills().size());

            // Step 3 — Gemini AI Scoring
            GeminiScoringService.GeminiResult geminiResult =
                    geminiService.score(resumeText, jobDescription, nlpResult);
            log.info("ATS Score: {} | Decision: {}", geminiResult.atsScore(), geminiResult.decision());

            // Step 4 — Assemble final result
            String seniorityLevel = nlpResult.experienceYears() >= 8 ? "Senior"
                    : nlpResult.experienceYears() >= 4 ? "Mid-Level" : "Junior";

            AnalysisResult result = AnalysisResult.builder()
                    .atsScore(geminiResult.atsScore())
                    .decision(geminiResult.decision())
                    .aiFeedback(geminiResult.feedback())
                    .matchingSkills(nlpResult.matchingSkills())
                    .missingSkills(nlpResult.missingSkills())
                    .keywordFrequency(nlpResult.keywordFrequency())
                    .experienceYears(nlpResult.experienceYears())
                    .seniorityLevel(seniorityLevel)
                    .build();

            return ResponseEntity.ok(result);

        } catch (Exception e) {
            log.error("Resume analysis failed", e);
            return ResponseEntity.internalServerError().build();
        }
    }

    @GetMapping("/health")
    public ResponseEntity<String> health() {
        return ResponseEntity.ok("Resume Analyzer API is running");
    }
}


