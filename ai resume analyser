package com.debales.resumeanalyzer.service;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import okhttp3.*;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.stereotype.Service;

import java.util.concurrent.TimeUnit;

/**
 * Integrates with the Google Gemini 1.5 Flash API to generate:
 *  - ATS compatibility score (0–100)
 *  - Seniority level classification
 *  - Actionable improvement suggestions
 */
@Service
public class GeminiScoringService {

    @Value("${gemini.api.key}")
    private String apiKey;

    @Value("${gemini.api.url}")
    private String apiUrl;

    private final OkHttpClient httpClient = new OkHttpClient.Builder()
            .connectTimeout(30, TimeUnit.SECONDS)
            .readTimeout(30, TimeUnit.SECONDS)
            .build();

    private final ObjectMapper objectMapper = new ObjectMapper();

    /**
     * Sends resume and job description to Gemini and parses its JSON response
     * containing score, decision label, feedback, and improvement points.
     */
    public GeminiResult score(String resumeText, String jobDescription,
                               NlpMatchingService.NlpResult nlpResult) throws Exception {

        String prompt = buildPrompt(resumeText, jobDescription, nlpResult);

        String requestBody = """
            {
              "contents": [
                {
                  "parts": [{"text": "%s"}]
                }
              ],
              "generationConfig": {
                "temperature": 0.3,
                "topP": 0.9,
                "responseMimeType": "application/json"
              }
            }
            """.formatted(prompt.replace("\"", "'").replace("\n", "\\n"));

        Request request = new Request.Builder()
                .url(apiUrl + "?key=" + apiKey)
                .post(RequestBody.create(requestBody, MediaType.parse("application/json")))
                .build();

        try (Response response = httpClient.newCall(request).execute()) {
            if (!response.isSuccessful()) {
                throw new RuntimeException("Gemini API error: " + response.code());
            }
            
            String body = response.body().string();
            JsonNode root = objectMapper.readTree(body);
            String content = root.at("/candidates/0/content/parts/0/text").asText();
            JsonNode result = objectMapper.readTree(content);

            return new GeminiResult(
                result.get("atsScore").asInt(),
                result.get("decision").asText(),
                result.get("feedback").asText(),
                result.get("seniorityLevel").asText(),
                result.get("improvements").toString()
            );
        }
    }

    private String buildPrompt(String resume, String jd,
                                NlpMatchingService.NlpResult nlp) {
        return """
            You are a senior ATS (Applicant Tracking System) expert and professional resume reviewer.
            
            Analyze the following resume against the job description and NLP data:
            
            === RESUME TEXT ===
            %s
            
            === JOB DESCRIPTION ===
            %s
            
            === NLP MATCH DATA ===
            Matching Skills: %s
            Missing Skills: %s
            Experience Years Detected: %d
            
            Respond ONLY with a valid JSON object matching this schema:
            {
              "atsScore": <integer 0-100>,
              "decision": "<Highly Recommended | Recommended | Neutral | Needs Improvement>",
              "feedback": "<2-3 sentence professional summary>",
              "seniorityLevel": "<Junior | Mid-Level | Senior | Lead | Principal>",
              "improvements": ["<actionable tip 1>", "<actionable tip 2>", "<actionable tip 3>"]
            }
            """.formatted(
                resume.substring(0, Math.min(resume.length(), 2000)),
                jd,
                nlp.matchingSkills(),
                nlp.missingSkills(),
                nlp.experienceYears()
            );
    }

    public record GeminiResult(
        int atsScore,
        String decision,
        String feedback,
        String seniorityLevel,
        String improvements
    ) {}
}


