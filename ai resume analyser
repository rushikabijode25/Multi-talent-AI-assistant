package com.debales.analyzer.controller;

import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;
import org.springframework.http.ResponseEntity;
import org.springframework.beans.factory.annotation.Autowired;
import com.debales.analyzer.service.ResumeService;
import java.util.Map;

@RestController
@RequestMapping("/api/v1/analyzer")
public class ResumeController {

    @Autowired
    private ResumeService resumeService;

    @PostMapping("/upload")
    public ResponseEntity<Map<String, Object>> analyzeResume(
            @RequestParam("file") MultipartFile file,
            @RequestParam("jobDescription") String jobDescription) {
        
        try {
            // 1. Extract text from PDF
            String resumeText = resumeService.extractTextFromPdf(file);
            
            // 2. Perform NLP Keyword Matching
            Map<String, Integer> keywordMatches = resumeService.performNlpMatching(resumeText, jobDescription);
            
            // 3. Request Gemini AI for Generative AI Scoring & Feedback
            Map<String, Object> aiFeedback = resumeService.generateAiFeedback(resumeText, jobDescription);
            
            // Combine Results
            aiFeedback.put("keywordsExtracted", keywordMatches);
            
            return ResponseEntity.ok(aiFeedback);
        } catch (Exception e) {
            return ResponseEntity.badRequest().body(Map.of("error", e.getMessage()));
        }
    }
}

// ==========================================
// SERVICE LAYER: NLP & GENERATIVE AI
// ==========================================
package com.debales.analyzer.service;

import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;
import org.apache.pdfbox.pdmodel.PDDocument;
import org.apache.pdfbox.text.PDFTextStripper;
import java.io.InputStream;
import java.util.Map;
import java.util.HashMap;

@Service
public class ResumeService {

    // --- 1. PDF Parser ---
    public String extractTextFromPdf(MultipartFile file) throws Exception {
        try (InputStream is = file.getInputStream(); PDDocument document = PDDocument.load(is)) {
            PDFTextStripper stripper = new PDFTextStripper();
            return stripper.getText(document);
        }
    }

    // --- 2. NLP Logic (Apache OpenNLP) ---
    public Map<String, Integer> performNlpMatching(String resume, String jd) {
        // Implementation of Tokenization & Named Entity Recognition (NER)
        // This is a simplified mockup of the NLP matching logic
        Map<String, Integer> matches = new HashMap<>();
        String[] requiredSkills = jd.toLowerCase().split("\\W+");
        String resumeLower = resume.toLowerCase();
        
        for (String skill : requiredSkills) {
            if (skill.length() > 3 && resumeLower.contains(skill)) {
                matches.put(skill, matches.getOrDefault(skill, 0) + 1);
            }
        }
        return matches;
    }

    // --- 3. Generative AI (Google Gemini API HTTP Client) ---
    public Map<String, Object> generateAiFeedback(String resume, String jd) {
        // Make an HTTP Request to Gemini API utilizing Java 11 HttpClient
        // System Prompt: "You are an ATS Scoring agent. Rank the following resume against the job description out of 100."
        
        // Mock payload representing successful parsing
        Map<String, Object> response = new HashMap<>();
        response.put("atsScore", 88);
        response.put("decision", "Highly Recommended");
        response.put("feedback", "Excellent match on backend engineering. Lacks specific mention of cloud deployment mechanisms.");
        return response;
    }
}
